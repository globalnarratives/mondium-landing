{
  "palettes": {
    "cyan": {
      "bg": "#090D10",
      "teal": "oklch(0.78 0.10 220)",
      "ink": "#E6EBEF",
      "label": "Cold Cyan — canonical"
    },
    "mint": {
      "bg": "#0D1413",
      "teal": "oklch(0.80 0.10 170)",
      "ink": "#EAEFEC",
      "label": "Mint — alternate"
    },
    "safety": {
      "black":     { "bg": "#000000", "fg": "#FFFFFF" },
      "white":     { "bg": "#FFFFFF", "fg": "#000000" },
      "parchment": { "bg": "#EFEAE0", "fg": "#17140F" }
    }
  },
  "type": {
    "sans": {
      "family": "Space Grotesk",
      "google": "https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&display=swap",
      "weights": [300, 400, 500, 600, 700]
    },
    "mono": {
      "family": "JetBrains Mono",
      "google": "https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&display=swap",
      "weights": [400, 500]
    },
    "roles": {
      "wordmark_primary":   { "family": "sans", "weight": 300, "tracking": "0.18em", "case": "upper" },
      "wordmark_backup":    { "family": "sans", "weight": 300, "tracking": "0.01em", "case": "cased" },
      "heading":            { "family": "sans", "weight": 400, "tracking": "-0.02em" },
      "heading_emphasis":   { "family": "sans", "weight": 500, "style": "italic", "color": "teal" },
      "body":               { "family": "sans", "weight": 300, "tracking": "0" },
      "tagline":            { "family": "mono", "weight": 400, "tracking": "0.30em", "case": "upper", "color": "teal" },
      "caption":            { "family": "mono", "weight": 400, "tracking": "0.20em", "case": "upper" },
      "motto":              { "family": "sans", "weight": 400, "tracking": "0.44em", "case": "upper", "color": "teal" }
    }
  },
  "mark": {
    "viewBox": "0 0 180 80",
    "aspect": "9:4",
    "strokes": { "outer": 1.2, "mid": 1.2, "inner": 1.4 },
    "opacities": { "outer": 0.35, "mid": 0.65, "inner": 1.0 },
    "core": { "x": 87, "y": 34, "w": 6, "h": 12, "fill": "teal" },
    "minHeight_px": 24,
    "lockup_minHeight_px": 40,
    "clearSpace": "1x bracket height"
  },
  "lockups": {
    "primary": {
      "kind": "horizontal",
      "order": ["mark", "rule", { "stack": ["wordmark_primary", "tagline"] }],
      "mark_width_px": 140,
      "rule": { "width_px": 1, "height_px": 60, "color": "ink", "opacity": 0.20 },
      "gap_px": 26
    },
    "backup": {
      "kind": "stacked",
      "order": ["mark", "wordmark_backup", "motto"],
      "mark_width_px": 170,
      "gap_wordmark_px": 10,
      "gap_motto_px": 4
    }
  },
  "strings": {
    "name": "Mondium",
    "wordmark_primary": "MONDIUM",
    "wordmark_backup": "Mondium",
    "tagline": "The world, encoded",
    "motto_latin": "OMNIA · VINCIT · VERITAS",
    "motto_gloss_english": "Truth conquers all"
  }
}
